<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.RECORD_AUDIO" />
    <uses-permission android:name="android.permission.READ_EXTERNAL_STORAGE"
        android:maxSdkVersion="32"/>
    <uses-permission android:name="android.permission.READ_MEDIA_IMAGES" />
    <!-- Daily reminder + streak alert + achievement notifications. -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />
    <uses-permission android:name="android.permission.WAKE_LOCK" />
    <uses-permission android:name="android.permission.VIBRATE" />

    <application
        android:allowBackup="false"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.Lingua"
        android:networkSecurityConfig="@xml/network_security_config">

        <activity
            android:name=".activities.SplashActivity"
            android:exported="true"
            android:theme="@style/Theme.Lingua.Splash">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <activity android:name=".activities.LoginActivity" android:exported="false"/>
        <activity android:name=".activities.RegisterActivity" android:exported="false"/>
        <activity android:name=".activities.OnboardingActivity" android:exported="false"/>
        <!-- BUG 4 FIX: launchMode="singleTop" cho các màn hình bottom-nav chính
             để tránh tạo instance mới mỗi khi user chuyển tab. Trước đây bấm
             Home → Vocab → Home → Vocab → AI sẽ tạo back stack 5 activity,
             bấm Back sẽ quay lại theo thứ tự ngược thay vì về Home. -->
        <activity android:name=".activities.MainActivity"
            android:exported="false"
            android:launchMode="singleTop"/>
        <activity android:name=".activities.VocabularyActivity"
            android:exported="false"
            android:launchMode="singleTop"/>
        <activity android:name=".activities.WordDetailActivity" android:exported="false"/>
        <activity android:name=".activities.PracticeActivity" android:exported="false"/>
        <activity android:name=".activities.LessonActivity" android:exported="false"/>
        <activity android:name=".activities.LessonResultActivity" android:exported="false"/>
        <!-- TD-5 FIX: FlashcardActivity là điểm đến của bottom-nav (qua SrsDeckPicker)
             nên cũng cần singleTop để tránh duplicate instance khi user
             FLAG_ACTIVITY_REORDER_TO_FRONT từ tab khác. -->
        <activity android:name=".activities.FlashcardActivity"
            android:exported="false"
            android:launchMode="singleTop"/>
        <activity android:name=".activities.SrsDeckPickerActivity"
            android:exported="false"
            android:launchMode="singleTop"/>
        <activity android:name=".activities.ShadowingActivity" android:exported="false"/>
        <activity android:name=".activities.AIRoleplayActivity"
            android:exported="false"
            android:launchMode="singleTop"/>
        <activity android:name=".activities.CourseDetailActivity" android:exported="false"/>
        <activity android:name=".activities.MyCoursesActivity" android:exported="false"/>
        <activity android:name=".activities.ProfileActivity"
            android:exported="false"
            android:launchMode="singleTop"/>
        <activity android:name=".activities.LeaderboardActivity" android:exported="false"/>
        <activity android:name=".activities.AchievementsActivity" android:exported="false"/>
        <activity android:name=".activities.QuestsActivity" android:exported="false"/>
        <activity android:name=".activities.FavoritesActivity" android:exported="false"/>
        <activity android:name=".activities.GrammarActivity" android:exported="false"/>
        <activity android:name=".activities.GrammarDetailActivity" android:exported="false"/>
        <activity android:name=".activities.MockTestActivity" android:exported="false"/>
        <activity android:name=".activities.MockTestDetailActivity" android:exported="false"/>
        <activity android:name=".activities.MockTestResultActivity" android:exported="false"/>
        <activity android:name=".activities.StatisticsActivity" android:exported="false"/>
        <activity android:name=".activities.SettingsActivity" android:exported="false"/>

        <!-- WorkManager auto-init provider is included automatically by androidx.work. -->

    </application>
</manifest>
