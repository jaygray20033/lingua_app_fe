<?xml version="1.0" encoding="utf-8"?>
<!-- Block backup/transfer of session credentials and shared prefs containing tokens. -->
<data-extraction-rules>
    <cloud-backup>
        <exclude domain="sharedpref" path="LinguaSession.xml" />
        <exclude domain="sharedpref" path="LinguaSession_fallback.xml" />
    </cloud-backup>
    <device-transfer>
        <exclude domain="sharedpref" path="LinguaSession.xml" />
        <exclude domain="sharedpref" path="LinguaSession_fallback.xml" />
    </device-transfer>
</data-extraction-rules>
