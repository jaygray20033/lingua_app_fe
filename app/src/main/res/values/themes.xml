<?xml version="1.0" encoding="utf-8"?>
<resources>

    <!-- ===== 2.3.2 Main Theme — tím gradient, NoActionBar ===== -->
    <style name="Theme.Lingua" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="colorPrimary">@color/brand_primary</item>
        <item name="colorPrimaryVariant">@color/brand_primary_dark</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorSecondary">@color/lingua_green</item>
        <item name="colorOnSecondary">@color/white</item>
        <item name="android:statusBarColor">@color/brand_primary</item>
        <item name="android:windowBackground">@color/surface_background</item>

        <!-- Bo góc Material -->
        <item name="shapeAppearanceMediumComponent">@style/ShapeAppearance.Lingua.Medium</item>
        <item name="shapeAppearanceLargeComponent">@style/ShapeAppearance.Lingua.Large</item>
        <item name="shapeAppearanceSmallComponent">@style/ShapeAppearance.Lingua.Small</item>

        <!-- Tab layout -->
        <item name="tabStyle">@style/Widget.Lingua.TabLayout</item>
        <!-- Bottom navigation -->
        <item name="bottomNavigationStyle">@style/Widget.Lingua.BottomNavigation</item>
        <!-- Buttons -->
        <item name="materialButtonStyle">@style/Widget.Lingua.Button</item>
        <!-- Cards -->
        <item name="materialCardViewStyle">@style/Widget.Lingua.Card</item>
    </style>

    <!-- Splash theme -->
    <style name="Theme.Lingua.Splash" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="colorPrimary">@color/brand_primary</item>
        <item name="android:windowBackground">@color/brand_primary</item>
        <item name="android:statusBarColor">@color/brand_primary</item>
    </style>

    <!-- ===== Shape Appearances ===== -->
    <style name="ShapeAppearance.Lingua.Small" parent="ShapeAppearance.MaterialComponents.SmallComponent">
        <item name="cornerSize">8dp</item>
    </style>

    <style name="ShapeAppearance.Lingua.Medium" parent="ShapeAppearance.MaterialComponents.MediumComponent">
        <item name="cornerSize">12dp</item>
    </style>

    <style name="ShapeAppearance.Lingua.Large" parent="ShapeAppearance.MaterialComponents.LargeComponent">
        <item name="cornerSize">16dp</item>
    </style>

    <!-- ===== Base Widget style ===== -->
    <style name="Widget.Lingua" parent="android:Widget" />

    <!-- ===== Card style chung ===== -->
    <style name="Widget.Lingua.Card" parent="Widget.MaterialComponents.CardView">
        <item name="cardCornerRadius">16dp</item>
        <item name="cardElevation">2dp</item>
        <item name="cardBackgroundColor">@color/surface_elevated</item>
        <item name="strokeColor">@color/card_border</item>
        <item name="strokeWidth">1dp</item>
    </style>

    <!-- Card nhỏ hơn (items trong danh sách) -->
    <style name="Widget.Lingua.Card.Small" parent="Widget.Lingua.Card">
        <item name="cardCornerRadius">12dp</item>
        <item name="cardElevation">1dp</item>
    </style>

    <!-- ===== Button styles ===== -->
    <style name="Widget.Lingua.Button" parent="Widget.MaterialComponents.Button">
        <item name="cornerRadius">12dp</item>
        <item name="backgroundTint">@color/brand_primary</item>
        <item name="android:textColor">@color/white</item>
        <item name="android:textStyle">bold</item>
        <item name="android:paddingTop">12dp</item>
        <item name="android:paddingBottom">12dp</item>
    </style>

    <style name="Widget.Lingua.Button.Green" parent="Widget.Lingua.Button">
        <item name="backgroundTint">@color/lingua_green</item>
    </style>

    <style name="Widget.Lingua.Button.Outlined" parent="Widget.MaterialComponents.Button.OutlinedButton">
        <item name="cornerRadius">12dp</item>
        <item name="strokeColor">@color/brand_primary</item>
        <item name="android:textColor">@color/brand_primary</item>
    </style>

    <!-- ===== TabLayout style ===== -->
    <style name="Widget.Lingua.TabLayout" parent="Widget.MaterialComponents.TabLayout">
        <item name="tabIndicatorColor">@color/brand_primary</item>
        <item name="tabSelectedTextColor">@color/brand_primary</item>
        <item name="tabTextColor">@color/text_label</item>
        <item name="tabBackground">@android:color/transparent</item>
        <item name="tabIndicatorHeight">3dp</item>
        <item name="tabRippleColor">@color/brand_primary</item>
    </style>

    <!-- ===== Bottom Navigation style ===== -->
    <style name="Widget.Lingua.BottomNavigation" parent="Widget.MaterialComponents.BottomNavigationView">
        <item name="itemIconTint">@color/bottom_nav_selector</item>
        <item name="itemTextColor">@color/bottom_nav_selector</item>
        <item name="itemBackground">@android:color/transparent</item>
    </style>

    <!-- ===== Toolbar ===== -->
    <style name="Widget.Lingua.Toolbar" parent="Widget.MaterialComponents.Toolbar.Primary">
        <item name="android:background">@color/surface_elevated</item>
        <item name="titleTextColor">@color/text_primary</item>
        <item name="navigationIconTint">@color/brand_primary</item>
    </style>

    <!-- Toolbar gradient (dùng cho banner header) -->
    <style name="Widget.Lingua.Toolbar.Gradient" parent="Widget.MaterialComponents.Toolbar.Primary">
        <item name="android:background">@drawable/bg_gradient_header</item>
        <item name="titleTextColor">@color/white</item>
        <item name="navigationIconTint">@color/white</item>
    </style>

    <!-- ===== Text appearances ===== -->
    <style name="TextAppearance.Lingua.Headline" parent="TextAppearance.MaterialComponents.Headline5">
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="TextAppearance.Lingua.Subtitle" parent="TextAppearance.MaterialComponents.Subtitle1">
        <item name="android:textColor">@color/text_secondary</item>
    </style>

    <style name="TextAppearance.Lingua.Caption" parent="TextAppearance.MaterialComponents.Caption">
        <item name="android:textColor">@color/text_label</item>
    </style>

    <!-- Badge styles -->
    <style name="Widget.Lingua.Badge">
        <item name="android:textSize">11sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:paddingStart">8dp</item>
        <item name="android:paddingEnd">8dp</item>
        <item name="android:paddingTop">3dp</item>
        <item name="android:paddingBottom">3dp</item>
    </style>

    <style name="Widget.Lingua.Badge.JLPT" parent="Widget.Lingua.Badge">
        <item name="android:background">@drawable/bg_badge_jlpt</item>
        <item name="android:textColor">@color/badge_jlpt</item>
    </style>

    <style name="Widget.Lingua.Badge.HSK" parent="Widget.Lingua.Badge">
        <item name="android:background">@drawable/bg_badge_hsk</item>
        <item name="android:textColor">@color/badge_hsk</item>
    </style>

    <style name="Widget.Lingua.Badge.CEFR" parent="Widget.Lingua.Badge">
        <item name="android:background">@drawable/bg_badge_cefr</item>
        <item name="android:textColor">@color/badge_cefr</item>
    </style>

</resources>
