<?xml version="1.0" encoding="utf-8"?>
<!-- 2.3 Redesign: Flashcard — surface_background, brand cards bo 16dp -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/surface_background"
    android:padding="16dp">

    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="horizontal" android:layout_marginBottom="8dp">
        <TextView android:id="@+id/tvProgress" android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1" android:textSize="16sp" android:textColor="@color/text_secondary" android:text="0 / 0"/>
        <TextView android:id="@+id/tvState" android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:textSize="14sp" android:textStyle="bold" android:textColor="@color/brand_primary"/>
    </LinearLayout>

    <!-- Session statistics -->
    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="8dp"
        app:cardCornerRadius="12dp"
        app:cardElevation="1dp"
        app:cardBackgroundColor="@color/surface_elevated">
        <TextView android:id="@+id/tvSessionStats"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="13sp"
            android:textColor="@color/text_primary"
            android:gravity="center"
            android:padding="10dp"
            android:text="🟦 New 0   🟧 Learning 0   🟩 Review 0"/>
    </androidx.cardview.widget.CardView>

    <ProgressBar android:id="@+id/progressBar" android:layout_width="wrap_content"
        android:layout_height="wrap_content" android:visibility="gone" android:layout_gravity="center_horizontal"/>

    <!-- Flashcard -->
    <FrameLayout android:id="@+id/layoutCard" android:layout_width="match_parent" android:layout_height="0dp"
        android:layout_weight="1" android:layout_marginBottom="16dp">

        <!-- Front -->
        <androidx.cardview.widget.CardView android:id="@+id/cardFront" android:layout_width="match_parent"
            android:layout_height="match_parent"
            app:cardCornerRadius="20dp" app:cardElevation="6dp" android:layout_margin="8dp">
            <LinearLayout android:layout_width="match_parent" android:layout_height="match_parent"
                android:gravity="center" android:orientation="vertical" android:background="#FFFDE7">
                <TextView android:id="@+id/tvFront" android:layout_width="wrap_content"
                    android:layout_height="wrap_content" android:textSize="36sp" android:textStyle="bold"
                    android:textColor="@color/text_primary" android:gravity="center"
                    android:text="Đang tải…"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Nhấn để lật 👆" android:textColor="@color/text_secondary"
                    android:textSize="14sp" android:layout_marginTop="16dp"/>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Back -->
        <androidx.cardview.widget.CardView android:id="@+id/cardBack" android:layout_width="match_parent"
            android:layout_height="match_parent"
            app:cardCornerRadius="20dp" app:cardElevation="6dp" android:layout_margin="8dp"
            android:visibility="gone">
            <LinearLayout android:layout_width="match_parent" android:layout_height="match_parent"
                android:gravity="center" android:orientation="vertical" android:background="#E8F5E9">
                <TextView android:id="@+id/tvBack" android:layout_width="wrap_content"
                    android:layout_height="wrap_content" android:textSize="28sp"
                    android:textColor="@color/text_primary" android:gravity="center"/>
            </LinearLayout>
        </androidx.cardview.widget.CardView>
    </FrameLayout>

    <TextView android:id="@+id/tvNextReview" android:layout_width="match_parent"
        android:layout_height="wrap_content" android:textSize="14sp" android:textColor="@color/text_secondary"
        android:gravity="center" android:layout_marginBottom="8dp" android:visibility="gone"/>

    <!-- Rating Buttons -->
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="horizontal" android:weightSum="4">

        <Button android:id="@+id/btnAgain" android:layout_width="0dp" android:layout_height="wrap_content"
            android:minHeight="56dp"
            android:layout_weight="1" android:text="😰\nAGAIN" android:backgroundTint="@color/lingua_red"
            android:textColor="@color/white" android:textSize="13sp" android:layout_margin="4dp" android:visibility="gone"/>

        <Button android:id="@+id/btnHard" android:layout_width="0dp" android:layout_height="wrap_content"
            android:minHeight="56dp"
            android:layout_weight="1" android:text="😅\nHARD" android:backgroundTint="@color/lingua_orange"
            android:textColor="@color/white" android:textSize="13sp" android:layout_margin="4dp" android:visibility="gone"/>

        <Button android:id="@+id/btnGood" android:layout_width="0dp" android:layout_height="wrap_content"
            android:minHeight="56dp"
            android:layout_weight="1" android:text="😊\nGOOD" android:backgroundTint="@color/brand_primary"
            android:textColor="@color/white" android:textSize="13sp" android:layout_margin="4dp" android:visibility="gone"/>

        <Button android:id="@+id/btnEasy" android:layout_width="0dp" android:layout_height="wrap_content"
            android:minHeight="56dp"
            android:layout_weight="1" android:text="😎\nEASY" android:backgroundTint="@color/lingua_green"
            android:textColor="@color/white" android:textSize="13sp" android:layout_margin="4dp" android:visibility="gone"/>
    </LinearLayout>
</LinearLayout>
