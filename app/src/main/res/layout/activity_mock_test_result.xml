<?xml version="1.0" encoding="utf-8"?>
<!-- 2.3 Redesign: Mock Test Result — surface_background, brand card 16dp -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:padding="24dp"
    android:background="@color/surface_background">

    <TextView android:id="@+id/tvVerdict"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="🎉 PASSED"
        android:textSize="36sp"
        android:textStyle="bold"
        android:textColor="@color/brand_primary"
        android:layout_marginBottom="20dp"/>

    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:cardCornerRadius="16dp"
        app:cardElevation="4dp"
        app:cardBackgroundColor="@color/surface_elevated"
        app:strokeColor="@color/card_border"
        app:strokeWidth="1dp">
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp"
            android:gravity="center">

            <TextView android:id="@+id/tvScore"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="56sp"
                android:textStyle="bold"
                android:textColor="@color/lingua_orange"
                android:text="0%"/>

            <TextView android:id="@+id/tvCorrect"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="16sp"
                android:textColor="@color/text_primary"
                android:layout_marginTop="6dp"
                android:text="Đúng 0/0"/>

            <TextView android:id="@+id/tvXp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="20sp"
                android:textStyle="bold"
                android:textColor="@color/brand_primary"
                android:layout_marginTop="14dp"
                android:text="⚡ +0 XP"/>
        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <Button android:id="@+id/btnDone"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:layout_marginTop="24dp"
        android:text="Hoàn tất"
        android:backgroundTint="@color/brand_primary"
        android:textColor="@color/white"
        android:textStyle="bold"
        android:textSize="16sp"/>
</LinearLayout>
