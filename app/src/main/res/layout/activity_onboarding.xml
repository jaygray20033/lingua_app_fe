<?xml version="1.0" encoding="utf-8"?>
<!-- U15 FIX: add a page-indicator overlay below the ViewPager2 so the user
     can see their progress through the onboarding flow. Previously there was
     no visual hint of how many pages remained. -->
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/lingua_light">

    <androidx.viewpager2.widget.ViewPager2
        android:id="@+id/pager"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <LinearLayout
        android:id="@+id/pageIndicator"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|center_horizontal"
        android:layout_marginBottom="24dp"
        android:orientation="horizontal" />
</FrameLayout>
