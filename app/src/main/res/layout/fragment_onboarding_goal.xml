<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="24dp"
    android:background="@color/lingua_light">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="🎯 Mục tiêu hàng ngày của bạn?"
        android:textSize="22sp"
        android:textStyle="bold"
        android:textColor="@color/lingua_dark"
        android:layout_marginTop="32dp"
        android:layout_marginBottom="8dp"/>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Đặt mục tiêu phù hợp với lịch của bạn. Bạn có thể đổi sau."
        android:textSize="14sp"
        android:textColor="@color/lingua_gray"
        android:layout_marginBottom="32dp"/>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerGoals"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"/>

    <!-- 6.1 FIX: thêm hàng nút Quay lại + Tiếp tục. -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="16dp">

        <Button
            android:id="@+id/btnBack"
            android:layout_width="0dp"
            android:layout_weight="0.35"
            android:layout_height="56dp"
            android:text="◀ Quay lại"
            android:textSize="14sp"
            android:textColor="@color/lingua_green"
            android:backgroundTint="@android:color/white"
            android:layout_marginEnd="8dp"/>

        <Button
            android:id="@+id/btnContinue"
            android:layout_width="0dp"
            android:layout_weight="0.65"
            android:layout_height="56dp"
            android:text="Tiếp tục"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="@android:color/white"
            android:backgroundTint="@color/lingua_green"
            android:enabled="false"/>
    </LinearLayout>
</LinearLayout>
