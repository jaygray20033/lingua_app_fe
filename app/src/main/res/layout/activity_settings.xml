<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/lingua_light"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Appearance -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🎨 Giao diện"
            android:textSize="14sp"
            android:textStyle="bold"
            android:textColor="@color/lingua_gray"
            android:layout_marginBottom="8dp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@android:color/white"
            android:padding="16dp"
            android:layout_marginBottom="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="🌙 Chế độ tối"
                    android:textSize="16sp"
                    android:textColor="@color/lingua_dark"/>
                <androidx.appcompat.widget.SwitchCompat
                    android:id="@+id/switchDarkMode"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>
            </LinearLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="@color/lingua_light"
                android:layout_marginVertical="12dp"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="🔊 Âm thanh phản hồi"
                    android:textSize="16sp"
                    android:textColor="@color/lingua_dark"/>
                <androidx.appcompat.widget.SwitchCompat
                    android:id="@+id/switchSound"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:checked="true"/>
            </LinearLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="@color/lingua_light"
                android:layout_marginVertical="12dp"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="📳 Rung khi sai"
                    android:textSize="16sp"
                    android:textColor="@color/lingua_dark"/>
                <androidx.appcompat.widget.SwitchCompat
                    android:id="@+id/switchHaptic"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:checked="true"/>
            </LinearLayout>
        </LinearLayout>

        <!-- Notifications -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🔔 Thông báo"
            android:textSize="14sp"
            android:textStyle="bold"
            android:textColor="@color/lingua_gray"
            android:layout_marginBottom="8dp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@android:color/white"
            android:padding="16dp"
            android:layout_marginBottom="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="⏰ Nhắc học hàng ngày"
                    android:textSize="16sp"
                    android:textColor="@color/lingua_dark"/>
                <androidx.appcompat.widget.SwitchCompat
                    android:id="@+id/switchDailyReminder"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:checked="true"/>
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginTop="8dp">
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Giờ nhắc nhở"
                    android:textSize="14sp"
                    android:textColor="@color/lingua_gray"/>
                <Button
                    android:id="@+id/btnReminderTime"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="20:00"
                    android:backgroundTint="@color/lingua_blue"
                    android:textColor="@android:color/white"/>
            </LinearLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="@color/lingua_light"
                android:layout_marginVertical="12dp"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="🔥 Cảnh báo streak sắp mất"
                    android:textSize="16sp"
                    android:textColor="@color/lingua_dark"/>
                <androidx.appcompat.widget.SwitchCompat
                    android:id="@+id/switchStreakAlert"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:checked="true"/>
            </LinearLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="@color/lingua_light"
                android:layout_marginVertical="12dp"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="🏆 Thông báo thành tựu"
                    android:textSize="16sp"
                    android:textColor="@color/lingua_dark"/>
                <androidx.appcompat.widget.SwitchCompat
                    android:id="@+id/switchAchievements"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:checked="true"/>
            </LinearLayout>
        </LinearLayout>

        <!-- Learning -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="📚 Học tập"
            android:textSize="14sp"
            android:textStyle="bold"
            android:textColor="@color/lingua_gray"
            android:layout_marginBottom="8dp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@android:color/white"
            android:padding="16dp"
            android:layout_marginBottom="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:padding="4dp"
                android:clickable="true"
                android:focusable="true"
                android:id="@+id/rowDailyGoal">
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="🎯 Mục tiêu hàng ngày"
                    android:textSize="16sp"
                    android:textColor="@color/lingua_dark"/>
                <TextView
                    android:id="@+id/tvDailyGoal"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="50 XP"
                    android:textSize="14sp"
                    android:textColor="@color/lingua_blue"
                    android:textStyle="bold"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="  ›"
                    android:textSize="20sp"
                    android:textColor="@color/lingua_gray"/>
            </LinearLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="@color/lingua_light"
                android:layout_marginVertical="12dp"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:padding="4dp"
                android:clickable="true"
                android:focusable="true"
                android:id="@+id/rowLanguage">
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="🌍 Ngôn ngữ đang học"
                    android:textSize="16sp"
                    android:textColor="@color/lingua_dark"/>
                <TextView
                    android:id="@+id/tvLanguage"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🇯🇵 Tiếng Nhật"
                    android:textSize="14sp"
                    android:textColor="@color/lingua_blue"
                    android:textStyle="bold"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="  ›"
                    android:textSize="20sp"
                    android:textColor="@color/lingua_gray"/>
            </LinearLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="@color/lingua_light"
                android:layout_marginVertical="12dp"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="📡 Tự động phát audio"
                    android:textSize="16sp"
                    android:textColor="@color/lingua_dark"/>
                <androidx.appcompat.widget.SwitchCompat
                    android:id="@+id/switchAutoplay"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:checked="true"/>
            </LinearLayout>
        </LinearLayout>

        <!-- Data / cache -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="💾 Dữ liệu &amp; bộ nhớ"
            android:textSize="14sp"
            android:textStyle="bold"
            android:textColor="@color/lingua_gray"
            android:layout_marginBottom="8dp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@android:color/white"
            android:padding="16dp"
            android:layout_marginBottom="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="📦 Cache offline (từ vựng)"
                    android:textSize="16sp"
                    android:textColor="@color/lingua_dark"/>
                <androidx.appcompat.widget.SwitchCompat
                    android:id="@+id/switchOffline"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:checked="true"/>
            </LinearLayout>

            <Button
                android:id="@+id/btnClearCache"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="🗑️ Xoá cache"
                android:layout_marginTop="12dp"
                android:backgroundTint="@color/lingua_red"
                android:textColor="@android:color/white"/>
        </LinearLayout>

        <!-- About -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="ℹ️ Về ứng dụng"
            android:textSize="14sp"
            android:textStyle="bold"
            android:textColor="@color/lingua_gray"
            android:layout_marginBottom="8dp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@android:color/white"
            android:padding="16dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Lingua"
                android:textSize="20sp"
                android:textStyle="bold"
                android:textColor="@color/lingua_dark"/>
            <!-- U26 FIX: text is set at runtime from PackageInfo.versionName so it
                 always matches build.gradle. The literal here is just a fallback
                 for the layout preview. -->
            <TextView
                android:id="@+id/tvVersion"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Phiên bản —"
                android:textSize="13sp"
                android:textColor="@color/lingua_gray"/>
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Học ngôn ngữ thông minh - vui vẻ - hiệu quả."
                android:textSize="13sp"
                android:textColor="@color/lingua_gray"
                android:layout_marginTop="8dp"/>
        </LinearLayout>
    </LinearLayout>
</ScrollView>
