<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/lingua_light">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="🏆 Bảng xếp hạng"
        android:textSize="22sp"
        android:textStyle="bold"
        android:textColor="@color/lingua_dark"
        android:padding="16dp"
        android:background="@color/white"
        android:elevation="4dp"/>

    <com.google.android.material.tabs.TabLayout
        android:id="@+id/tabPeriod"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@android:color/white"
        app:tabMode="fixed"
        app:tabGravity="fill"
        app:tabIndicatorColor="@color/lingua_green"
        app:tabSelectedTextColor="@color/lingua_green"
        app:tabTextColor="@color/lingua_gray"/>

    <TextView
        android:id="@+id/tvMyRank"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="12dp"
        android:layout_margin="8dp"
        android:background="@color/white"
        android:textSize="14sp"
        android:textColor="@color/lingua_dark"
        android:visibility="gone"
        android:text=""/>

    <ProgressBar android:id="@+id/progressBar"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:layout_marginTop="16dp"
        android:visibility="gone"/>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerLeaderboard"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:padding="6dp"
        app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"/>
</LinearLayout>
