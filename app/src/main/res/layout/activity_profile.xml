<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/lingua_light">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Avatar & Name -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="4dp">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp"
                android:gravity="center">

                <FrameLayout
                    android:layout_width="92dp"
                    android:layout_height="92dp"
                    android:layout_marginBottom="8dp">

                    <ImageView android:id="@+id/imgAvatar"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:scaleType="centerCrop"
                        android:background="@drawable/btn_circle_green"
                        android:contentDescription="Avatar"/>

                    <TextView android:id="@+id/tvAvatar"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:gravity="center"
                        android:text="👤"
                        android:textSize="40sp"/>

                    <Button android:id="@+id/btnChangeAvatar"
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:layout_gravity="bottom|end"
                        android:text="📷"
                        android:textSize="14sp"
                        android:padding="0dp"
                        android:minWidth="0dp"
                        android:minHeight="0dp"
                        android:backgroundTint="@color/lingua_blue"/>
                </FrameLayout>

                <TextView android:id="@+id/tvDisplayName"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="22sp"
                    android:textStyle="bold"
                    android:textColor="@color/lingua_dark"/>

                <TextView android:id="@+id/tvEmail"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="14sp"
                    android:textColor="@color/lingua_gray"
                    android:layout_marginTop="2dp"/>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Stats -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="4dp">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="14dp">

                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:gravity="center" android:orientation="vertical">
                    <TextView android:id="@+id/tvXp" android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:textSize="22sp" android:textStyle="bold" android:textColor="@color/lingua_orange" android:text="0"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="@string/xp" android:textSize="12sp" android:textColor="@color/lingua_gray"/>
                </LinearLayout>

                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:gravity="center" android:orientation="vertical">
                    <TextView android:id="@+id/tvLevel" android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:textSize="22sp" android:textStyle="bold" android:textColor="@color/lingua_blue" android:text="1"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="@string/level" android:textSize="12sp" android:textColor="@color/lingua_gray"/>
                </LinearLayout>

                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:gravity="center" android:orientation="vertical">
                    <TextView android:id="@+id/tvStreak" android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:textSize="22sp" android:textStyle="bold" android:textColor="@color/lingua_red" android:text="0"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="@string/streak" android:textSize="12sp" android:textColor="@color/lingua_gray"/>
                </LinearLayout>

                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:gravity="center" android:orientation="vertical">
                    <TextView android:id="@+id/tvGems" android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:textSize="22sp" android:textStyle="bold" android:textColor="@color/lingua_green" android:text="0"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="@string/gems" android:textSize="12sp" android:textColor="@color/lingua_gray"/>
                </LinearLayout>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Daily goal & Streak Freeze card -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="3dp">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="14dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="⚙️ Cài đặt mục tiêu"
                    android:textStyle="bold"
                    android:textSize="15sp"
                    android:textColor="@color/lingua_dark"
                    android:layout_marginBottom="8dp"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">
                    <TextView
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="wrap_content"
                        android:text="🎯 Mục tiêu hàng ngày"
                        android:textSize="14sp"
                        android:textColor="@color/lingua_dark"/>
                    <TextView android:id="@+id/tvDailyGoalValue"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="50 XP"
                        android:textStyle="bold"
                        android:textColor="@color/lingua_orange"
                        android:layout_marginEnd="8dp"/>
                    <Button android:id="@+id/btnSetDailyGoal"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Đổi"
                        android:textSize="12sp"
                        android:minWidth="0dp"
                        android:minHeight="0dp"
                        android:backgroundTint="@color/lingua_blue"
                        android:textColor="@color/white"/>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginTop="10dp">
                    <TextView
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="wrap_content"
                        android:text="🧊 Streak Freeze"
                        android:textSize="14sp"
                        android:textColor="@color/lingua_dark"/>
                    <TextView android:id="@+id/tvStreakFreezeCount"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="x0"
                        android:textStyle="bold"
                        android:textColor="@color/lingua_blue"
                        android:layout_marginEnd="8dp"/>
                    <Button android:id="@+id/btnBuyStreakFreeze"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Mua (200 💎)"
                        android:textSize="12sp"
                        android:minWidth="0dp"
                        android:minHeight="0dp"
                        android:backgroundTint="@color/lingua_blue"
                        android:textColor="@color/white"/>
                </LinearLayout>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Action Buttons -->
        <Button android:id="@+id/btnLeaderboard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="🏆 Bảng xếp hạng"
            android:backgroundTint="@color/lingua_yellow"
            android:textColor="@color/lingua_dark"
            android:layout_marginBottom="6dp"/>

        <Button android:id="@+id/btnAchievements"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="🎖 Thành tựu"
            android:backgroundTint="@color/lingua_blue"
            android:textColor="@color/white"
            android:layout_marginBottom="6dp"/>

        <Button android:id="@+id/btnQuests"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="🎯 Nhiệm vụ hàng ngày"
            android:backgroundTint="@color/lingua_green"
            android:textColor="@color/white"
            android:layout_marginBottom="6dp"/>

        <Button android:id="@+id/btnMyCourses"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="📚 Khoá học của tôi"
            android:backgroundTint="@color/lingua_orange"
            android:textColor="@color/white"
            android:layout_marginBottom="6dp"/>

        <Button android:id="@+id/btnFavorites"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="🔖 Mục yêu thích"
            android:backgroundTint="@color/lingua_red"
            android:textColor="@color/white"
            android:layout_marginBottom="6dp"/>

        <Button android:id="@+id/btnStatistics"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="📈 Tiến độ học"
            android:backgroundTint="@color/lingua_blue"
            android:textColor="@color/white"
            android:layout_marginBottom="6dp"/>

        <Button android:id="@+id/btnSettings"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="⚙️ Cài đặt"
            android:backgroundTint="@color/lingua_gray"
            android:textColor="@color/white"
            android:layout_marginBottom="6dp"/>

        <Button android:id="@+id/btnChangePassword"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="🔐 Đổi mật khẩu"
            android:backgroundTint="@color/lingua_dark"
            android:textColor="@color/white"
            android:layout_marginBottom="20dp"/>

        <!-- Logout -->
        <Button android:id="@+id/btnLogout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/logout"
            android:backgroundTint="@color/lingua_red"
            android:textColor="@color/white"/>
    </LinearLayout>
</ScrollView>
