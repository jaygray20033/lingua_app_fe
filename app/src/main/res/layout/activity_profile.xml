<?xml version="1.0" encoding="utf-8"?>
<!-- 2.3 Redesign: Profile — gradient header tím→hồng, card bo 16dp -->
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/surface_background">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- ===== HERO BANNER gradient tím→hồng ===== -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_gradient_header"
            android:orientation="vertical"
            android:gravity="center"
            android:paddingTop="28dp"
            android:paddingBottom="28dp"
            android:paddingStart="20dp"
            android:paddingEnd="20dp">

            <!-- Avatar circle -->
            <FrameLayout
                android:layout_width="88dp"
                android:layout_height="88dp"
                android:layout_marginBottom="10dp">

                <ImageView android:id="@+id/imgAvatar"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:scaleType="centerCrop"
                    android:background="@drawable/btn_circle_green"
                    android:contentDescription="Avatar"/>

                <TextView android:id="@+id/tvAvatar"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:gravity="center"
                    android:text="👤"
                    android:textSize="38sp"/>

                <Button android:id="@+id/btnChangeAvatar"
                    android:layout_width="30dp"
                    android:layout_height="30dp"
                    android:layout_gravity="bottom|end"
                    android:text="📷"
                    android:textSize="13sp"
                    android:padding="0dp"
                    android:minWidth="0dp"
                    android:minHeight="0dp"
                    android:backgroundTint="@color/brand_primary"/>
            </FrameLayout>

            <TextView android:id="@+id/tvDisplayName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="22sp"
                android:textStyle="bold"
                android:textColor="@color/white"/>

            <TextView android:id="@+id/tvEmail"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="14sp"
                android:textColor="#CCFFFFFF"
                android:layout_marginTop="2dp"/>
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Stats row card -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="2dp"
                app:cardBackgroundColor="@color/surface_elevated"
                app:strokeColor="@color/card_border"
                app:strokeWidth="1dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="16dp"
                    android:weightSum="4">

                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:gravity="center" android:orientation="vertical">
                        <TextView android:id="@+id/tvXp"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:textSize="20sp" android:textStyle="bold"
                            android:textColor="@color/lingua_orange" android:text="0"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="@string/xp" android:textSize="11sp"
                            android:textColor="@color/text_secondary"/>
                    </LinearLayout>

                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:gravity="center" android:orientation="vertical">
                        <TextView android:id="@+id/tvLevel"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:textSize="20sp" android:textStyle="bold"
                            android:textColor="@color/brand_primary" android:text="1"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="@string/level" android:textSize="11sp"
                            android:textColor="@color/text_secondary"/>
                    </LinearLayout>

                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:gravity="center" android:orientation="vertical">
                        <TextView android:id="@+id/tvStreak"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:textSize="20sp" android:textStyle="bold"
                            android:textColor="@color/lingua_red" android:text="0"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="@string/streak" android:textSize="11sp"
                            android:textColor="@color/text_secondary"/>
                    </LinearLayout>

                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:gravity="center" android:orientation="vertical">
                        <TextView android:id="@+id/tvGems"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:textSize="20sp" android:textStyle="bold"
                            android:textColor="@color/lingua_green" android:text="0"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="@string/gems" android:textSize="11sp"
                            android:textColor="@color/text_secondary"/>
                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Daily goal & Streak Freeze card -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="2dp"
                app:cardBackgroundColor="@color/surface_elevated"
                app:strokeColor="@color/card_border"
                app:strokeWidth="1dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="⚙️ Cài đặt mục tiêu"
                        android:textStyle="bold"
                        android:textSize="15sp"
                        android:textColor="@color/text_primary"
                        android:layout_marginBottom="12dp"/>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">
                        <TextView
                            android:layout_width="0dp"
                            android:layout_weight="1"
                            android:layout_height="wrap_content"
                            android:text="🎯 Mục tiêu hàng ngày"
                            android:textSize="14sp"
                            android:textColor="@color/text_primary"/>
                        <TextView android:id="@+id/tvDailyGoalValue"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="50 XP"
                            android:textStyle="bold"
                            android:textColor="@color/brand_primary"
                            android:layout_marginEnd="8dp"/>
                        <Button android:id="@+id/btnSetDailyGoal"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Đổi"
                            android:textSize="12sp"
                            android:minWidth="0dp"
                            android:minHeight="0dp"
                            android:backgroundTint="@color/brand_primary"
                            android:textColor="@color/white"/>
                    </LinearLayout>

                    <View android:layout_width="match_parent" android:layout_height="1dp"
                        android:background="@color/divider_line"
                        android:layout_marginTop="12dp"
                        android:layout_marginBottom="12dp"/>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">
                        <TextView
                            android:layout_width="0dp"
                            android:layout_weight="1"
                            android:layout_height="wrap_content"
                            android:text="🧊 Streak Freeze"
                            android:textSize="14sp"
                            android:textColor="@color/text_primary"/>
                        <TextView android:id="@+id/tvStreakFreezeCount"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="x0"
                            android:textStyle="bold"
                            android:textColor="@color/brand_primary"
                            android:layout_marginEnd="8dp"/>
                        <Button android:id="@+id/btnBuyStreakFreeze"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Mua (200 💎)"
                            android:textSize="12sp"
                            android:minWidth="0dp"
                            android:minHeight="0dp"
                            android:backgroundTint="@color/brand_primary"
                            android:textColor="@color/white"/>
                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Action Buttons — dùng MaterialButton style full width với gravity left text -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="2dp"
                app:cardBackgroundColor="@color/surface_elevated"
                app:strokeColor="@color/card_border"
                app:strokeWidth="1dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="6dp">

                    <Button android:id="@+id/btnLeaderboard"
                        style="?android:attr/borderlessButtonStyle"
                        android:layout_width="match_parent"
                        android:layout_height="52dp"
                        android:text="🏆  Bảng xếp hạng"
                        android:textSize="15sp"
                        android:textColor="@color/text_primary"
                        android:gravity="start|center_vertical"
                        android:paddingStart="10dp"/>

                    <View android:layout_width="match_parent" android:layout_height="1dp"
                        android:background="@color/divider_line" android:layout_marginStart="10dp"/>

                    <Button android:id="@+id/btnAchievements"
                        style="?android:attr/borderlessButtonStyle"
                        android:layout_width="match_parent"
                        android:layout_height="52dp"
                        android:text="🎖  Thành tựu"
                        android:textSize="15sp"
                        android:textColor="@color/text_primary"
                        android:gravity="start|center_vertical"
                        android:paddingStart="10dp"/>

                    <View android:layout_width="match_parent" android:layout_height="1dp"
                        android:background="@color/divider_line" android:layout_marginStart="10dp"/>

                    <Button android:id="@+id/btnQuests"
                        style="?android:attr/borderlessButtonStyle"
                        android:layout_width="match_parent"
                        android:layout_height="52dp"
                        android:text="🎯  Nhiệm vụ hàng ngày"
                        android:textSize="15sp"
                        android:textColor="@color/text_primary"
                        android:gravity="start|center_vertical"
                        android:paddingStart="10dp"/>

                    <View android:layout_width="match_parent" android:layout_height="1dp"
                        android:background="@color/divider_line" android:layout_marginStart="10dp"/>

                    <Button android:id="@+id/btnMyCourses"
                        style="?android:attr/borderlessButtonStyle"
                        android:layout_width="match_parent"
                        android:layout_height="52dp"
                        android:text="📚  Khoá học của tôi"
                        android:textSize="15sp"
                        android:textColor="@color/text_primary"
                        android:gravity="start|center_vertical"
                        android:paddingStart="10dp"/>

                    <View android:layout_width="match_parent" android:layout_height="1dp"
                        android:background="@color/divider_line" android:layout_marginStart="10dp"/>

                    <Button android:id="@+id/btnFavorites"
                        style="?android:attr/borderlessButtonStyle"
                        android:layout_width="match_parent"
                        android:layout_height="52dp"
                        android:text="🔖  Mục yêu thích"
                        android:textSize="15sp"
                        android:textColor="@color/text_primary"
                        android:gravity="start|center_vertical"
                        android:paddingStart="10dp"/>

                    <View android:layout_width="match_parent" android:layout_height="1dp"
                        android:background="@color/divider_line" android:layout_marginStart="10dp"/>

                    <Button android:id="@+id/btnStatistics"
                        style="?android:attr/borderlessButtonStyle"
                        android:layout_width="match_parent"
                        android:layout_height="52dp"
                        android:text="📈  Tiến độ học"
                        android:textSize="15sp"
                        android:textColor="@color/text_primary"
                        android:gravity="start|center_vertical"
                        android:paddingStart="10dp"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Settings / Security card -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="2dp"
                app:cardBackgroundColor="@color/surface_elevated"
                app:strokeColor="@color/card_border"
                app:strokeWidth="1dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="6dp">

                    <Button android:id="@+id/btnSettings"
                        style="?android:attr/borderlessButtonStyle"
                        android:layout_width="match_parent"
                        android:layout_height="52dp"
                        android:text="⚙️  Cài đặt"
                        android:textSize="15sp"
                        android:textColor="@color/text_primary"
                        android:gravity="start|center_vertical"
                        android:paddingStart="10dp"/>

                    <View android:layout_width="match_parent" android:layout_height="1dp"
                        android:background="@color/divider_line" android:layout_marginStart="10dp"/>

                    <Button android:id="@+id/btnChangePassword"
                        style="?android:attr/borderlessButtonStyle"
                        android:layout_width="match_parent"
                        android:layout_height="52dp"
                        android:text="🔐  Đổi mật khẩu"
                        android:textSize="15sp"
                        android:textColor="@color/text_primary"
                        android:gravity="start|center_vertical"
                        android:paddingStart="10dp"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Logout button -->
            <Button android:id="@+id/btnLogout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/logout"
                android:backgroundTint="@color/lingua_red"
                android:textColor="@color/white"
                android:textStyle="bold"
                android:layout_marginBottom="24dp"/>
        </LinearLayout>
    </LinearLayout>
</ScrollView>
