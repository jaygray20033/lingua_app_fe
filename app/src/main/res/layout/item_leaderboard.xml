<?xml version="1.0" encoding="utf-8"?>
<!-- 2.3 Redesign: Leaderboard item — bo góc 16dp, tím brand -->
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="4dp"
    android:layout_marginVertical="4dp"
    app:cardCornerRadius="14dp"
    app:cardElevation="2dp"
    app:cardBackgroundColor="@color/surface_elevated"
    app:strokeColor="@color/card_border"
    app:strokeWidth="1dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="14dp"
        android:gravity="center_vertical">

        <!-- Rank number / trophy -->
        <TextView android:id="@+id/tvRank"
            android:layout_width="42dp"
            android:layout_height="wrap_content"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="@color/brand_primary"
            android:gravity="center"/>

        <!-- Avatar circle -->
        <ImageView android:id="@+id/ivAvatar"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_marginStart="8dp"
            android:src="@android:drawable/ic_menu_myplaces"
            android:background="@drawable/btn_circle_green"
            android:scaleType="centerCrop"
            android:contentDescription="Avatar"/>

        <!-- Name -->
        <TextView android:id="@+id/tvName"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:textSize="15sp"
            android:textStyle="bold"
            android:textColor="@color/text_primary"
            android:layout_marginStart="12dp"/>

        <!-- XP badge -->
        <TextView android:id="@+id/tvXp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="14sp"
            android:textStyle="bold"
            android:textColor="@color/brand_primary"/>
    </LinearLayout>
</androidx.cardview.widget.CardView>
