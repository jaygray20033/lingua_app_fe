<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="8dp"
    android:layout_marginVertical="4dp"
    app:cardCornerRadius="8dp"
    app:cardElevation="2dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="14dp"
        android:gravity="center_vertical">

        <TextView android:id="@+id/tvRank"
            android:layout_width="40dp"
            android:layout_height="wrap_content"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="@color/lingua_orange"
            android:gravity="center"/>

        <!-- 6.10 FIX: thêm avatar 40dp bên cạnh tên user trên bảng xếp hạng -->
        <ImageView android:id="@+id/ivAvatar"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_marginStart="8dp"
            android:src="@android:drawable/ic_menu_myplaces"
            android:background="@color/lingua_light"
            android:scaleType="centerCrop"
            android:contentDescription="Avatar"/>

        <TextView android:id="@+id/tvName"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:textSize="16sp"
            android:textColor="@color/lingua_dark"
            android:layout_marginStart="12dp"/>

        <TextView android:id="@+id/tvXp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="@color/lingua_orange"/>
    </LinearLayout>
</androidx.cardview.widget.CardView>
